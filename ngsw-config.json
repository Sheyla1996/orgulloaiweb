{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "dataGroups": [
    {
      "name": "api-estatica",
      "urls": [
        "https://apiorgullo.sheylamartinez.es/asociacion",
        "https://apiorgullo.sheylamartinez.es/telefono",
        "https://apiorgullo.sheylamartinez.es/whtasapp"
      ],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 50,
        "maxAge": "12h"
      }
    },
    {
      "name": "api-viva",
      "urls": [
        "https://apiorgullo.sheylamartinez.es/ubicacion",
        "https://apiorgullo.sheylamartinez.es/carroza"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 20,
        "maxAge": "30s",
        "timeout": "3s"
      }
    }
  ],
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/*.css",
          "/*.js"
        ],
        "urls": [
          "/",
          "/list-carrozas",
          "/list-asociaciones",
          "/list-telefonos",
          "/login"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/assets/**",
          "/*.(png|jpg|jpeg|svg|webp|ico|woff2|woff|ttf|eot)"
        ]
      }
    }
  ]
}
